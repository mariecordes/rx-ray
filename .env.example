# Legacy/local MySQL configuration for RxNorm data exploration.
# The deployed app uses committed parquet runtime data and does not need MySQL.
MYSQL_HOME=/opt/homebrew/opt/mysql
RXNORM_USER=root
RXNORM_PASSWORD=<YOUR_PASSWORD_HERE>
RXNORM_DATABASE=RxNorm
RXNORM_HOST=localhost

# OpenFDA API configuration
OPENFDA_BASE_URL="https://api.fda.gov/drug/label.json"

# Backend CORS configuration.
# Set EXTRA_CORS_ORIGINS on Railway to your Vercel production URL.
EXTRA_CORS_ORIGINS=
ALLOW_ALL_CORS=false

# Frontend proxy configuration.
# Set this in Vercel, not Railway, to the public Railway backend URL.
BACKEND_URL=http://localhost:8000

# Query extraction LLM configuration.
# Leave unset to use deterministic extraction.
QUERY_EXTRACTION_OPENAI_API_KEY=your_openai_key_here
QUERY_EXTRACTION_OPENAI_MODEL=gpt-5.5

# Answer synthesis LLM configuration.
# Leave unset to skip generated summaries and keep deterministic evidence views.
ANSWER_SYNTHESIS_OPENAI_API_KEY=your_openai_key_here
ANSWER_SYNTHESIS_OPENAI_MODEL=gpt-5.5

# Optional answer critic configuration.
# If omitted, the critic reuses ANSWER_SYNTHESIS_*.
ANSWER_CRITIC_OPENAI_API_KEY=
ANSWER_CRITIC_OPENAI_MODEL=
